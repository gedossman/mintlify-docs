{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Interf",
  "colors": {
    "primary": "#2563EB",
    "light": "#2563EB",
    "dark": "#2563EB"
  },
  "favicon": "/logo/favicon/favicon.ico",
  "logo": {
    "light": "/logo/logo-interf.png",
    "dark": "/logo/logo-interf.png"
  },
  "font": {
    "headings": {
      "family": "Red Hat Display"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "navbar": {
    "links": [
      {
        "label": "Trust Center",
        "href": "https://trust.interf.com/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Contact",
      "href": "mailto:info@interf.com"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Trust Center",
          "href": "https://trust.interf.com/",
          "icon": "shield-check"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/interf",
      "x": "https://x.com/interf",
      "website": "https://interf.com"
    }
  },
  "metadata": {
    "og:site_name": "Interf",
    "og:title": "Interf - The Interface for Agent Readiness",
    "og:description": "Interf provides the open Agent Readiness Protocol and Gateway to simulate enterprise deployment before implementation begins. Readiness-as-Code.",
    "og:image": "/logo/logo-interf.png",
    "twitter:card": "summary",
    "twitter:title": "Interf - The Interface for Agent Readiness",
    "twitter:description": "Interf provides the open Agent Readiness Protocol and Gateway to simulate enterprise deployment before implementation begins. Readiness-as-Code."
  }
}
